{"nodes": [{"id": "mtxscheduler_iife_singleton", "label": "__mtxScheduler IIFE singleton", "type": "singleton", "description": "IIFE-initialized global singleton (window.__mtxScheduler). Guards against double-init. Provides schedule, cancel, clearAll, getTime, list, requestPermission, _restoreTimeouts, _processReminders. Persists state in sessionStorage '__mtx_schedule_v1'.", "file_type": "code", "source_file": "components/mtx-scheduler.jsx", "source_location": "line 24-183", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "mtxscheduler_schedule", "label": "__mtxScheduler.schedule(id, time, label, itemType)", "type": "method", "description": "Schedules a notification for a given id at HH:MM time with label and semantic itemType (ritual|content|focus|reminder). Clears existing timeout, creates new setTimeout, saves to sessionStorage, dispatches 'mtx:scheduled' CustomEvent, calls _bridgeUpsert, then calls __mtxIAAgenda.checkConflict.", "file_type": "code", "source_file": "components/mtx-scheduler.jsx", "source_location": "line 116-125", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "mtxscheduler_cancel", "label": "__mtxScheduler.cancel(id)", "type": "method", "description": "Cancels a scheduled item: clears timeout, removes from _items, saves sessionStorage, dispatches 'mtx:scheduled', calls _bridgeRemove to remove from agenda.", "file_type": "code", "source_file": "components/mtx-scheduler.jsx", "source_location": "line 127-133", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "mtxscheduler_clearall", "label": "__mtxScheduler.clearAll()", "type": "method", "description": "Clears all scheduled items: iterates _items, clears timeouts and bridge-removes each, resets _items to {}, saves sessionStorage, dispatches 'mtx:scheduled' with id=null.", "file_type": "code", "source_file": "components/mtx-scheduler.jsx", "source_location": "line 145-153", "source_url