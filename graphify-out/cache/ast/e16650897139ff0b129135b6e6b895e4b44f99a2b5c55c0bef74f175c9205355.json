              color: partialPct > 0 ? accent : 'var(--ink-1)',\n                  transition:'background .25s, color .25s',\n                }}\n              >\n                <IcPlay size={14} stroke=\"currentColor\"/>\n              </button>\n            </div>\n          );\n        })", "source_file": "/Users/juandiego/Projects/Mentex app/screens/home-active.jsx", "source_location": "L382"}, {"caller_nid": "screens_home_active_emit", "callee": "dispatchEvent", "source_file": "/Users/juandiego/Projects/Mentex app/screens/home-active.jsx", "source_location": "L452"}, {"caller_nid": "screens_home_active_stopinterval", "callee": "clearInterval", "source_file": "/Users/juandiego/Projects/Mentex app/screens/home-active.jsx", "source_location": "L455"}, {"caller_nid": "screens_home_active_startinterval", "callee": "setInterval", "source_file": "/Users/juandiego/Projects/Mentex app/screens/home-active.jsx", "source_location": "L460"}, {"caller_nid": "screens_home_active_useappsbreak", "callee": "useReducer", "source_file": "/Users/juandiego/Projects/Mentex app/screens/home-active.jsx", "source_location": "L503"}, {"caller_nid": "screens_home_active_useappsbreak", "callee": "useEffect", "source_file": "/Users/juandiego/Projects/Mentex app/screens/home-active.jsx", "source_location": "L504"}, {"caller_nid": "screens_home_active_useappsbreak", "callee": "get", "source_file": "/Users/juandiego/Projects/Mentex app/screens/home-active.jsx", "source_location": "L510"}, {"caller_nid": "screens_home_active_appsprotectioncard", "callee": "floor", "source_file": "/Users/juandiego/Projects/Mentex app/screens/home-active.jsx", "source_location": "L583"}, {"caller_nid": "screens_home_active_appsprotectioncard", "callee": "padStart", "source_file": "/Users/juandiego/Projects/Mentex app/screens/home-active.jsx", "source_location": "L585"}, {"caller_nid": "screens_home_active_appsprotectioncard", "callee": "String", "source_file": "/Users/juandiego/Projects/Mentex app/screens/home-ac