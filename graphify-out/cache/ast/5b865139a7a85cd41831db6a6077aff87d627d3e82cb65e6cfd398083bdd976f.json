_home_inactive_homeinactive", "callee": "map", "source_file": "/Users/juandiego/Projects/Mentex app/screens/home-inactive.jsx", "source_location": "L610"}, {"caller_nid": "screens_home_inactive_homeinactive", "callee": "glassFor", "source_file": "/Users/juandiego/Projects/Mentex app/screens/home-inactive.jsx", "source_location": "L649"}, {"caller_nid": "screens_home_inactive_homeinactive", "callee": "(() => {\n            const visibleIds = Array.from(new Set([..._DEFAULT_VISIBLE_APP_IDS, ...blockedApps]));\n            const items = visibleIds\n              .map(id => APPS.find(a => a.id === id))\n              .filter(Boolean);\n            return items.map((app, i) => {\n              const on = blockedApps.includes(app.id);\n              return (\n                <div key={app.id} onClick={() => toggleApp(app.id)} className=\"mtx-tap\" style={{\n                  display:'flex', alignItems:'center', gap:12,\n                  padding:'10px 12px', cursor:'pointer',\n                  borderTop: i === 0 ? 0 : '0.5px solid rgba(255,255,255,0.05)'\n                }}>\n                  <app.Icon size={36}/>\n                  <div style={{ flex:1, minWidth:0 }}>\n                    <div style={{ fontSize:14, fontWeight:500, color:'var(--ink-1)', letterSpacing:'-0.01em' }}>{app.name}</div>\n                    <div style={{ fontSize:11, color:'var(--ink-3)' }}>{app.subtitle}</div>\n                  </div>\n                  <button className=\"mtx-switch\" data-on={on ? '1' : '0'}\n                    onClick={(e) => { e.stopPropagation(); toggleApp(app.id); }}>\n                    <i/>\n                  </button>\n                </div>\n              );\n            });\n          })", "source_file": "/Users/juandiego/Projects/Mentex app/screens/home-inactive.jsx", "source_location": "L654"}, {"caller_nid": "screens_home_inactive_homeinactive", "callee": "map", "source_file": "/Users/juandiego/Projects/Mentex app/screens/home-inactive.jsx", "source_location"