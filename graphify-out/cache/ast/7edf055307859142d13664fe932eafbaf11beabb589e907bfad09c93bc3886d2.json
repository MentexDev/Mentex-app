assName=\"mtx-switch\" data-on={on ? '1' : '0'}\n                    onClick={(e) => { e.stopPropagation(); toggleApp(app.id); }}>\n                    <i/>\n                  </button>\n                </div>\n              );\n            });\n          })", "source_file": "/Users/juandiego/Projects/Mentex app/screens/home-inactive.jsx", "source_location": "L986"}, {"caller_nid": "screens_home_inactive_homeinactive", "callee": "map", "source_file": "/Users/juandiego/Projects/Mentex app/screens/home-inactive.jsx", "source_location": "L1051"}]}