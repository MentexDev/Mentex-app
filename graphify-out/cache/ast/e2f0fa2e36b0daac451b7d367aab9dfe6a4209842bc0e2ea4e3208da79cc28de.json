)',\n                      filter:`drop-shadow(0 0 4px ${accent}66)`,\n                    }}/>\n                </svg>\n              )}\n              <button\n                onClick={(e) => { e.stopPropagation(); handleActivate(); }}\n                aria-label={effectiveDone\n                  ? `Revisar ${a.title} \u00b7 completado`\n                  : `Reproducir ${a.title}${partialPct > 0 ? ` \u00b7 ${Math.round(partialPct * 100)}% completado` : ''}`}\n                className=\"mtx-tap\"\n                style={{\n                  position:'absolute', inset:STROKE + 1,\n                  borderRadius:999, border:0,\n                  background: showRing ? `${accent}1a` : 'rgba(255,255,255,0.06)',\n                  display:'flex', alignItems:'center', justifyContent:'center',\n                  cursor:'pointer',\n                  color: showRing ? accent : 'var(--ink-1)',\n                  transition:'background .25s, color .25s',\n                }}\n              >\n                {effectiveDone\n                  ? <IcCheck size={14} stroke=\"currentColor\" strokeWidth={2.6}/>\n                  : <IcPlay size={14} stroke=\"currentColor\"/>}\n              </button>\n            </div>\n          );\n        })", "source_file": "/Users/juandiego/Projects/Mentex app/screens/home-active.jsx", "source_location": "L394"}, {"caller_nid": "screens_home_active_emit", "callee": "dispatchEvent", "source_file": "/Users/juandiego/Projects/Mentex app/screens/home-active.jsx", "source_location": "L470"}, {"caller_nid": "screens_home_active_stopinterval", "callee": "clearInterval", "source_file": "/Users/juandiego/Projects/Mentex app/screens/home-active.jsx", "source_location": "L473"}, {"caller_nid": "screens_home_active_startinterval", "callee": "setInterval", "source_file": "/Users/juandiego/Projects/Mentex app/screens/home-active.jsx", "source_location": "L478"}, {"caller_nid": "screens_home_active_useappsbreak", "callee": "useReducer", "source_file": "/Use