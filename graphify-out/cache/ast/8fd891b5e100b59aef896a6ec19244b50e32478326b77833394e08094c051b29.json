ns_profile_profilescreen", "callee": "filter", "source_file": "/Users/juandiego/Projects/Mentex app/screens/profile.jsx", "source_location": "L2935"}, {"caller_nid": "screens_profile_profilescreen", "callee": "map", "source_file": "/Users/juandiego/Projects/Mentex app/screens/profile.jsx", "source_location": "L2971"}, {"caller_nid": "screens_profile_profilescreen", "callee": "map", "source_file": "/Users/juandiego/Projects/Mentex app/screens/profile.jsx", "source_location": "L3039"}, {"caller_nid": "screens_profile_profilescreen", "callee": "(() => {\n        const overlayRoot = typeof document !== 'undefined' ? document.getElementById('mtx-overlay-root') : null;\n        const sheet = (\n          <EditProfileSheet\n            profile={profile}\n            onClose={() => setEditOpen(false)}\n            onSave={handleSaveProfile}\n          />\n        );\n        return overlayRoot && window.ReactDOM\n          ? window.ReactDOM.createPortal(sheet, overlayRoot)\n          : sheet;\n      })", "source_file": "/Users/juandiego/Projects/Mentex app/screens/profile.jsx", "source_location": "L3059"}, {"caller_nid": "screens_profile_profilescreen", "callee": "(() => {\n        const ShareSheetCmp = window.ShareSheet;\n        const overlayRoot = typeof document !== 'undefined' ? document.getElementById('mtx-overlay-root') : null;\n        const sheet = <ShareSheetCmp item={shareEntity} onClose={() => setShareEntity(null)}/>;\n        return overlayRoot && window.ReactDOM\n          ? window.ReactDOM.createPortal(sheet, overlayRoot)\n          : sheet;\n      })", "source_file": "/Users/juandiego/Projects/Mentex app/screens/profile.jsx", "source_location": "L3074"}, {"caller_nid": "screens_profile_profilescreen", "callee": "(() => {\n        const overlayRoot = typeof document !== 'undefined' ? document.getElementById('mtx-overlay-root') : null;\n        const sheet = (\n          <window.AchievementSheet\n            achievement={achievementSheet}\n            onClose={() => setAchievementSheet(null)}\n          />\n        );\n        return overlayRoot && window.ReactDOM\n          ? window.ReactDOM.createPortal(sheet, overlayRoot)\n          : sheet;\n      })", "source_file": "/Users/juandiego/Projects/Mentex app/screens/profile.jsx", "source_location": "L3084"}, {"caller_nid": "screens_profile_profilescreen", "callee": "(() => {\n        const overlayRoot = typeof document !== 'undefined' ? document.getElementById('mtx-overlay-root') : null;\n        // Profile enriquecido con hours para que los sheets puedan derivar datos\n        const enrichedProfile = {\n          ...profile,\n          hours: hoursLearned,\n          followers: followersCount,\n        };\n        let sheet = null;\n        if (statSheet === 'level' && window.LevelSheet) {\n          sheet = <window.LevelSheet profile={enrichedProfile} onClose={() => setStatSheet(null)}/>;\n        } else if (statSheet === 'hours' && window.HoursSheet) {\n          sheet = <window.HoursSheet profile={enrichedProfile} onClose={() => setStatSheet(null)}/>;\n        } else if (statSheet === 'followers' && window.FollowersSheet) {\n          sheet = <window.FollowersSheet profile={enrichedProfile} onClose={() => setStatSheet(null)} isOwn={true}/>;\n        }\n        if (!sheet) return null;\n        return overlayRoot && window.ReactDOM\n          ? window.ReactDOM.createPortal(sheet, overlayRoot)\n          : sheet;\n      })", "source_file": "/Users/juandiego/Projects/Mentex app/screens/profile.jsx", "source_location": "L3098"}, {"caller_nid": "screens_profile_profilescreen", "callee": "(() => {\n        const ThreadCmp = window.ReviewThreadScreen;\n        const overlayRoot = typeof document !== 'undefined' ? document.getElementById('mtx-overlay-root') : null;\n        const screen = (\n          <ThreadCmp\n            review={threadReview}\n            onClose={() => setThreadReview(null)}\n            onItemTap={(item) => {\n              setThreadReview(null);\n              setTimeout(() => handleItemTap({ itemId: item.id }), 200);\n            }}\n            onShareTap={(entity) => setShareEntity(entity)}\n            onAuthorTap={() => { /* es el propio user \u2014 no navega */ }}\n          />\n        );\n        return overlayRoot && window.ReactDOM\n          ? window.ReactDOM.createPortal(screen, overlayRoot)\n          : screen;\n      })", "source_file": "/Users/juandiego/Projects/Mentex app/screens/profile.jsx", "source_location": "L3121"}]}