}>\n                    {review.author.tagline}\n                  </div>\n                </div>\n                <CommunityRating rating={review.rating} size={12}/>\n              </div>\n            );\n          })", "source_file": "/Users/juandiego/Projects/Mentex app/screens/thread-flow.jsx", "source_location": "L573"}, {"caller_nid": "screens_thread_flow_reviewthreadscreen", "callee": "find", "source_file": "/Users/juandiego/Projects/Mentex app/screens/thread-flow.jsx", "source_location": "L657"}, {"caller_nid": "screens_thread_flow_reviewthreadscreen", "callee": "map", "source_file": "/Users/juandiego/Projects/Mentex app/screens/thread-flow.jsx", "source_location": "L703"}, {"caller_nid": "screens_thread_flow_reviewthreadscreen", "callee": "map", "source_file": "/Users/juandiego/Projects/Mentex app/screens/thread-flow.jsx", "source_location": "L767"}]}